# =====================================================================
# Enterprise Hybrid RAG Engine - Environment Configuration Template
# =====================================================================
# Copy this file to `.env` in the same directory and fill in your credentials.
# Do NOT commit your actual `.env` file containing secrets to version control!

# 1. API Keys & Credentials
# Obtain your API key from the Groq Console: https://console.groq.com/
GROQ_API_KEY="gsk_your_groq_api_key_here"

# 2. Python Environment Paths (Optional but recommended for terminal runtimes)
# Set to the project root directory so python can resolve local module imports correctly
PYTHONPATH="."
